{
  "expo": {
    "name": "MandiPro",
    "slug": "mandipro",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "mandipro",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mandipro.app",
      "infoPlist": {
        "NSCameraUsageDescription": "MandiPro uses the camera to scan barcodes and capture images."
      }
    },
    "android": {
      "package": "com.mandipro.app"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ]
  }
}
